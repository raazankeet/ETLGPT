# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials to version control
# =============================================================================

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# SQL Server Connection
SQL_SERVER_NAME=your_server_name.database.windows.net
SQL_DATABASE_NAME=your_database_name
SQL_USERNAME=your_username
SQL_PASSWORD=your_password

# Optional: SQL Server Driver (default: ODBC Driver 18 for SQL Server)
# SQL_DRIVER=ODBC Driver 18 for SQL Server

# Application Settings
APP_LOG_LEVEL=INFO
MAX_QUERY_HISTORY=1000
MAX_RETRY_ATTEMPTS=3
DEFAULT_QUERY_TIMEOUT=30

# Embedding Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.70

# Optional: Custom paths (defaults shown)
# CHROMA_PATH=./data/chroma_db
# EMBED_CONFIG_PATH=config/embedding_config.yaml
# PREFS_PATH=config/prefs.json
